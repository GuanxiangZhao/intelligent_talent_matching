<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.intelligent_talent_matching.mapper.FileMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.intelligent_talent_matching.entity.File">
        <id column="file_id" property="fileId" />
        <result column="file_user_id" property="fileUserId" />
        <result column="file_name" property="fileName" />
        <result column="file_url" property="fileUrl" />
        <result column="file_type" property="fileType" />
        <result column="file_create_time" property="fileCreateTime" />
        <result column="file_update_time" property="fileUpdateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        file_id, file_user_id, file_name, file_url, file_type, file_create_time, file_update_time
    </sql>

</mapper>
