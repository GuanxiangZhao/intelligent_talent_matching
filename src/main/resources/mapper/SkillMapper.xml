<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.intelligent_talent_matching.mapper.SkillMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.intelligent_talent_matching.entity.Skill">
        <id column="skill_id" property="skillId" />
        <result column="skill_name" property="skillName" />
        <result column="skill_create_time" property="skillCreateTime" />
        <result column="skill_update_time" property="skillUpdateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        skill_id, skill_name, skill_create_time, skill_update_time
    </sql>

</mapper>
